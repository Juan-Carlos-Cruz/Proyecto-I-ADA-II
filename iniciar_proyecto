#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PID_FILE="$ROOT_DIR/.backend.pid"
CHILD_PID_FILE="$ROOT_DIR/.backend.child.pid"
FRONTEND_FILE="$ROOT_DIR/riego_interfaz_frontend.html"
BACKEND_BINARY="$ROOT_DIR/backend/bin/riego_backend"
SUPERVISOR_SCRIPT="$ROOT_DIR/backend/scripts/supervisar_backend.sh"
LOG_DIR="$ROOT_DIR/backend/logs"
STDOUT_LOG="$LOG_DIR/backend.out.log"
STDERR_LOG="$LOG_DIR/backend.err.log"
PORT="${RIEGO_BACKEND_PORT:-8080}"
AUTO_OPEN=1

if [[ "${1:-}" == "--no-open" ]]; then
  AUTO_OPEN=0
fi

healthcheck() {
  python3 - "$PORT" <<'PY'
import sys
import urllib.request

port = sys.argv[1]
url = f"http://127.0.0.1:{port}/health"

try:
    with urllib.request.urlopen(url, timeout=1.2) as response:
        sys.exit(0 if response.status == 200 else 1)
except Exception:
    sys.exit(1)
PY
}

backend_binary_is_compatible() {
  if [[ ! -x "$BACKEND_BINARY" ]]; then
    return 1
  fi

  if ! command -v file >/dev/null 2>&1; then
    return 0
  fi

  local description
  description="$(file -b "$BACKEND_BINARY" 2>/dev/null || true)"
  local kernel
  kernel="$(uname -s)"
  local machine
  machine="$(uname -m)"

  case "$kernel" in
    Darwin)
      [[ "$description" == *"Mach-O"* ]] || return 1
      case "$machine" in
        arm64)
          [[ "$description" == *"arm64"* || "$description" == *"ARM64"* ]] || return 1
          ;;
        x86_64)
          [[ "$description" == *"x86_64"* || "$description" == *"x86-64"* || "$description" == *"x86-64"* ]] || return 1
          ;;
      esac
      ;;
    Linux)
      [[ "$description" == *"ELF"* ]] || return 1
      case "$machine" in
        x86_64)
          [[ "$description" == *"x86-64"* || "$description" == *"x86_64"* ]] || return 1
          ;;
        aarch64|arm64)
          [[ "$description" == *"aarch64"* || "$description" == *"ARM aarch64"* || "$description" == *"ARM64"* ]] || return 1
          ;;
      esac
      ;;
  esac

  return 0
}

find_backend_pids() {
  local pids=()

  if command -v pgrep >/dev/null 2>&1; then
    while IFS= read -r pid; do
      [[ -n "$pid" ]] && pids+=("$pid")
    done < <(pgrep -f "backend/bin/riego_backend --port $PORT" 2>/dev/null || true)

    while IFS= read -r pid; do
      [[ -n "$pid" ]] && pids+=("$pid")
    done < <(pgrep -f "backend/scripts/supervisar_backend.sh $PORT" 2>/dev/null || true)
  fi

  if command -v lsof >/dev/null 2>&1; then
    while IFS= read -r pid; do
      [[ -n "$pid" ]] && pids+=("$pid")
    done < <(lsof -ti tcp:"$PORT" -sTCP:LISTEN 2>/dev/null || true)
  fi

  printf '%s\n' "${pids[@]}" | awk 'NF { print }' | sort -u
}

write_pid_files_from_detection() {
  local detected_pids
  detected_pids="$(find_backend_pids || true)"

  if [[ -n "$detected_pids" ]]; then
    local first_pid
    first_pid="$(printf '%s\n' "$detected_pids" | head -n 1)"
    printf '%s\n' "$first_pid" > "$PID_FILE"

    local last_pid
    last_pid="$(printf '%s\n' "$detected_pids" | tail -n 1)"
    if [[ -n "$last_pid" ]]; then
      printf '%s\n' "$last_pid" > "$CHILD_PID_FILE"
    fi
  fi
}

cleanup_pid() {
  if [[ -f "$PID_FILE" ]]; then
    local pid
    pid="$(cat "$PID_FILE")"

    if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
      kill "$pid" 2>/dev/null || true
      sleep 1
    fi

    rm -f "$PID_FILE"
  fi

  if [[ -f "$CHILD_PID_FILE" ]]; then
    local child_pid
    child_pid="$(cat "$CHILD_PID_FILE")"

    if [[ -n "$child_pid" ]] && kill -0 "$child_pid" 2>/dev/null; then
      kill "$child_pid" 2>/dev/null || true
      sleep 1
    fi

    rm -f "$CHILD_PID_FILE"
  fi
}

# Cross-platform file opener: macOS uses 'open', Linux uses 'xdg-open'
open_file() {
  local target="$1"
  if [[ "$(uname -s)" == "Darwin" ]]; then
    open "$target" >/dev/null 2>&1 &
  elif command -v xdg-open >/dev/null 2>&1; then
    xdg-open "$target" >/dev/null 2>&1 &
  fi
}

mkdir -p "$LOG_DIR"

if healthcheck; then
  write_pid_files_from_detection
  echo "Backend ya estaba activo en http://127.0.0.1:$PORT"
else
  cleanup_pid

  echo "Limpiando binario anterior para forzar reconstruccion local..."
  make -C "$ROOT_DIR" clean-backend >/dev/null 2>&1 || true

  echo "Compilando backend provisional..."
  make -C "$ROOT_DIR" backend

  chmod +x "$SUPERVISOR_SCRIPT"

  echo "Iniciando backend provisional..."
  nohup "$SUPERVISOR_SCRIPT" "$PORT" >/dev/null 2>&1 < /dev/null &
  SUPERVISOR_PID=$!
  echo "$SUPERVISOR_PID" > "$PID_FILE"

  READY=0
  for _ in $(seq 1 40); do
    if healthcheck; then
      READY=1
      break
    fi
    sleep 0.25
  done

  if [[ "$READY" -ne 1 ]]; then
    echo "No se pudo iniciar el backend provisional." >&2
    echo "Revisa: $STDERR_LOG" >&2
    tail -n 40 "$STDERR_LOG" 2>/dev/null || true
    exit 1
  fi

  echo "Backend activo en http://127.0.0.1:$PORT"
fi

echo "Frontend listo en:"
echo "  $FRONTEND_FILE"
echo "Logs del backend:"
echo "  $STDOUT_LOG"
echo "  $STDERR_LOG"

if [[ "$AUTO_OPEN" -eq 1 ]]; then
  open_file "$FRONTEND_FILE"
fi