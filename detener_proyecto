#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PID_FILE="$ROOT_DIR/.backend.pid"
CHILD_PID_FILE="$ROOT_DIR/.backend.child.pid"

if [[ ! -f "$PID_FILE" ]]; then
  echo "No hay PID registrado para el backend."
else
  PID="$(cat "$PID_FILE")"

  if [[ -n "$PID" ]] && kill -0 "$PID" 2>/dev/null; then
    kill "$PID"
    echo "Supervisor del backend detenido (PID $PID)."
  else
    echo "El supervisor registrado ya no estaba activo."
  fi
fi

if [[ -f "$CHILD_PID_FILE" ]]; then
  CHILD_PID="$(cat "$CHILD_PID_FILE")"

  if [[ -n "$CHILD_PID" ]] && kill -0 "$CHILD_PID" 2>/dev/null; then
    kill "$CHILD_PID" 2>/dev/null || true
    echo "Proceso backend detenido (PID $CHILD_PID)."
  fi
fi

rm -f "$PID_FILE" "$CHILD_PID_FILE"
